# Локальные секреты. Здесь лежит пароль Proxmox.
.env

# Реальные tfvars могут содержать SSH-ключи, адреса и секреты.
*.tfvars
!terraform.tfvars.example

# Рабочая директория Terraform с загруженными provider plugins.
.terraform/

# Lock-файл можно коммитить в командных проектах. В учебном pet-проекте
# оставляем его локальным, чтобы не плодить служебные изменения.
.terraform.lock.hcl

# State содержит реальные идентификаторы ресурсов и может содержать sensitive data.
terraform.tfstate
terraform.tfstate.*

# Диагностические файлы Terraform.
crash.log
crash.*.log

# Локальные override-файлы не должны попадать в общий репозиторий.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated by Terraform/Ansible.
ansible/inventories/generated/hosts.yml
ansible/artifacts/*
!ansible/artifacts/.gitkeep
