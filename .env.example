# URL веб-интерфейса и API Proxmox VE.
PROXMOX_API_URL=https://192.168.31.200:8006/

# Пользователь Proxmox. Для первого запуска удобно root@pam,
# но для production лучше создать отдельного пользователя или API token.
PROXMOX_USER=root@pam

# Примерное значение. Реальный пароль храните только в .env.
PROXMOX_PASSWORD=change-me

# Имя ноды внутри Proxmox, не IP-адрес.
PROXMOX_NODE=pve

# SSH-доступ нужен provider'у для загрузки cloud-init snippets.
PROXMOX_SSH_USERNAME=root
PROXMOX_SSH_NODE_ADDRESS=192.168.31.200

# Опционально: раскомментируйте, если Terraform Registry доступен только через proxy.
# HTTPS_PROXY=http://proxy.example.local:3128
# HTTP_PROXY=http://proxy.example.local:3128
# NO_PROXY=localhost,127.0.0.1,192.168.31.200
# TF_REGISTRY_CLIENT_TIMEOUT=60
